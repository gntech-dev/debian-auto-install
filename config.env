#!/usr/bin/env bash
# config.env – User-configurable settings for debian-auto-install
#
# Edit this file to match your environment, then host the entire repository
# (or at least this file and the scripts/ directory) at a publicly reachable
# URL and update SCRIPTS_URL below.
#
# The preseed late_command downloads setup.sh from SCRIPTS_URL; setup.sh
# in turn downloads this file and every other script from the same base URL.

# ---------------------------------------------------------------------------
# GitHub / hosting
# ---------------------------------------------------------------------------

# Base URL where all scripts (including this file) are served.
# Must end WITHOUT a trailing slash.
SCRIPTS_URL="https://raw.githubusercontent.com/gntech-dev/debian-auto-install/main/scripts"

# ---------------------------------------------------------------------------
# SSH key provisioning
# ---------------------------------------------------------------------------

# URL that returns one or more SSH public keys (one per line).
# Examples:
#   https://github.com/<username>.keys
#   https://example.com/authorized_keys
# Leave empty to skip SSH key provisioning.
SSH_KEYS_URL=""

# Comma-separated list of local system users whose ~/.ssh/authorized_keys
# should receive the keys fetched from SSH_KEYS_URL.
# "root" is always included when SSH_KEYS_URL is set.
SSH_KEY_USERS="root,admin"

# ---------------------------------------------------------------------------
# System identity
# ---------------------------------------------------------------------------

HOSTNAME="debian-server"
DOMAIN="local"
TIMEZONE="UTC"

# ---------------------------------------------------------------------------
# Network configuration
# ---------------------------------------------------------------------------

# Primary network interface name.
NETWORK_INTERFACE="eth0"

# Set STATIC_IP to configure a static address; leave empty to use DHCP.
# Example: STATIC_IP="192.168.1.100"
STATIC_IP=""
NETMASK="255.255.255.0"
PREFIX_LENGTH="24"       # Used when writing systemd-networkd config
GATEWAY=""
DNS_SERVERS="8.8.8.8 8.8.4.4"
DNS_SEARCH="${DOMAIN}"

# ---------------------------------------------------------------------------
# Btrfs mount options
# ---------------------------------------------------------------------------

# Applied to every Btrfs subvolume mount in /etc/fstab.
BTRFS_OPTS="defaults,compress=zstd:3,noatime,space_cache=v2"

# ---------------------------------------------------------------------------
# Snapper
# ---------------------------------------------------------------------------

# Maximum number of timeline snapshots to keep.
SNAPPER_TIMELINE_MAX_HOURLY=5
SNAPPER_TIMELINE_MAX_DAILY=7
SNAPPER_TIMELINE_MAX_MONTHLY=0
SNAPPER_TIMELINE_MAX_YEARLY=0

# Number of numbered (APT) snapshots to keep.
SNAPPER_NUMBER_MAX_COUNT=10
